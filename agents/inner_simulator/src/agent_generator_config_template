# This property is used by the clients to connect to IceStorm.
Proxies.TopicManager = "IceStorm/TopicManager:default -p 9999"

# Proxies for publishes interfaces
Proxies.VisualElementsPubPrefix = ""

# Proxies for required interfaces
Proxies.Camera360RGB = "camera360rgb:tcp -h localhost -p 0"


# --- Common Agent Data ---
Agent.id = 0 # Change id
Agent.name = "concept_{{concept_name}}"

# --- Single Instance Configuration ---
# Use this if you only have one graph.
Agent.configFile = ""
Agent.domain = 0
Agent.tree = true
Agent.graph = true
Agent.2d = true
Agent.3d = true

# --- Multiple Instance Template ---
# If you define sub-instances, the single instance config above will be ignored.
Agent.work.configFile = ""
Agent.work.domain = 0
Agent.work.tree = true
Agent.work.graph = true
Agent.work.2d = true
Agent.work.3d = true

Period.Compute = 100
Period.Emergency = 500

Component.Debug.Verbose = true

Ice.Warn.Connections = "0"
Ice.Trace.Network = "0"
Ice.Trace.Protocol = "0"
Ice.MessageSizeMax = "20004800"