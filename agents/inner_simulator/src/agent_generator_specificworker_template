    def publish_status_to_dsr(self):
        """ Publishes the status of the concept to DSR."""
        # check if we have found the concept in this compute step. if so, publish the possible_concept object node to DSR. If not, destroy it (if it exists)
        if not self.has_concept_been_found:
            # check if we have to destroy the node in DSR
            if self.g.get_node(f"object_{CONCEPT_NAME}") is not None:
                # destroy node (edge is implicitly destroyed)
                console.print(f"Destroying object node {CONCEPT_NAME}", style="bold red")
                self.g.delete_node(f"object_{CONCEPT_NAME}")
        else:
            # check if we have to create the node in DSR
            if self.g.get_node(f"object_{CONCEPT_NAME}") is None:
                # create node
                console.print(f"Creating object node {CONCEPT_NAME}", style="bold green")
                object_node = Node(agent_id=self.agent_id, name=f"object_{CONCEPT_NAME}", type="object")
                self.g.insert_node(object_node)                
                # create edge
                robot_node = self.g.get_node("robot")
                if robot_node is None:
                    console.print("Robot node not found in DSR graph. This should NOT happen. Exiting...", style="bold red")
                    exit()
                edge = Edge(object_node.id, robot_node.id, "thinks", self.agent_id)
                self.g.insert_or_assign_edge(edge)
                

    def show_compute_time_step(self):
        """
        Get the time step between compute calls
        :return: time
        """
        time_step = time.time() - self.actual_time
        self.actual_time = time.time()
        if time.time() - self.print_time > 5:
            self.print_time = time.time()
            console.print(f"Compute frequency: {1/time_step:.2f} Hz", style="bold blue")
            
        return time_step
    
    
    def _build_equirect_remap(self):
        """
        Precomputes the cubemap → equirectangular remap tables.
        For each pixel (u, v) in the output equirectangular image, we compute
        the spherical direction, find the corresponding cubemap face, and store
        the source coordinates to be used later with cv2.remap.
        """
        W, H = self.equirect_w, self.equirect_h
        F = self.cube_face_size

        # Cubemap face axes in a local frame where +X=forward, +Y=left, +Z=up.
        # Each tuple: (forward_axis, right_axis, up_axis) matching the
        # OpenGL view produced by PyBullet's computeViewMatrix for that face.
        #                       forward          right (s)        up (u)
        self._cube_faces = [
            (( 1,  0,  0), ( 0, -1,  0), ( 0,  0,  1)),  # 0  Front  +X
            ((-1,  0,  0), ( 0,  1,  0), ( 0,  0,  1)),  # 1  Back   −X
            (( 0,  1,  0), ( 1,  0,  0), ( 0,  0,  1)),  # 2  Left   +Y
            (( 0, -1,  0), (-1,  0,  0), ( 0,  0,  1)),  # 3  Right  −Y
            (( 0,  0,  1), ( 0, -1,  0), (-1,  0,  0)),  # 4  Top    +Z
            (( 0,  0, -1), ( 0, -1,  0), ( 1,  0,  0)),  # 5  Bottom −Z
        ]

        u_px = np.arange(W, dtype=np.float64)
        v_px = np.arange(H, dtype=np.float64)
        u_grid, v_grid = np.meshgrid(u_px, v_px)

        # Spherical coordinates for each output pixel
        theta = 2.0 * np.pi * u_grid / W              # longitude  [0, 2π)
        phi   = np.pi * (0.5 - v_grid / H)            # latitude   [π/2 … −π/2]

        # 3-D direction in local frame
        dx = np.cos(phi) * np.cos(theta)   # forward
        dy = np.cos(phi) * np.sin(theta)   # left
        dz = np.sin(phi)                   # up

        # Determine dominant axis → cubemap face
        abs_d = np.stack([np.abs(dx), np.abs(dy), np.abs(dz)], axis=-1)
        axis = np.argmax(abs_d, axis=-1)                # 0=X, 1=Y, 2=Z
        dominant_val = np.choose(axis, [dx, dy, dz])
        face_idx = axis * 2 + (dominant_val < 0).astype(int)

        d = np.stack([dx, dy, dz], axis=-1)             # (H, W, 3)

        # Build remap arrays.  All six faces are laid out side-by-side in a
        # single atlas of shape (F, 6·F, 4) so cv2.remap can handle them in
        # one call.
        map_x = np.zeros((H, W), dtype=np.float32)
        map_y = np.zeros((H, W), dtype=np.float32)

        for fi in range(6):
            mask = face_idx == fi
            if not np.any(mask):
                continue
            fwd = np.array(self._cube_faces[fi][0], dtype=np.float64)
            s_v = np.array(self._cube_faces[fi][1], dtype=np.float64)
            u_v = np.array(self._cube_faces[fi][2], dtype=np.float64)

            d_m = d[mask]                                # (N, 3)
            dot_f = d_m @ fwd                            # projection on face normal
            nx = (d_m @ s_v) / dot_f                     # normalised screen-x  [−1, 1]
            ny = (d_m @ u_v) / dot_f                     # normalised screen-y  [−1, 1]

            px = (nx + 1.0) / 2.0 * (F - 1)             # pixel-x in face
            py = (1.0 - ny) / 2.0 * (F - 1)             # pixel-y in face

            map_x[mask] = (fi * F + px).astype(np.float32)
            map_y[mask] = py.astype(np.float32)

        self._remap_x = map_x
        self._remap_y = map_y

    def render_360_image(self, cam_pos: list, forward: list) -> np.ndarray:
        """
        Renders a 360° equirectangular image using a 6-face cubemap.

        :param cam_pos: [x, y, z] world position of the camera
        :param forward: [fx, fy] normalized 2-D forward direction vector
        :return: numpy array (equirect_h, equirect_w, 4) RGBA
        """
        fx, fy = forward
        F = self.cube_face_size

        # World-space target positions and up vectors for six cubemap faces.
        # Local frame: +X = (fx,fy,0), +Y = (−fy,fx,0), +Z = (0,0,1)
        face_params = [
            ([cam_pos[0] + fx,  cam_pos[1] + fy,  cam_pos[2]],     [0, 0, 1]),        # Front
            ([cam_pos[0] - fx,  cam_pos[1] - fy,  cam_pos[2]],     [0, 0, 1]),        # Back
            ([cam_pos[0] - fy,  cam_pos[1] + fx,  cam_pos[2]],     [0, 0, 1]),        # Left
            ([cam_pos[0] + fy,  cam_pos[1] - fx,  cam_pos[2]],     [0, 0, 1]),        # Right
            ([cam_pos[0],       cam_pos[1],       cam_pos[2] + 1],  [-fx, -fy, 0]),   # Top
            ([cam_pos[0],       cam_pos[1],       cam_pos[2] - 1],  [fx, fy, 0]),     # Bottom
        ]

        # Render the 6 faces and pack them into a horizontal atlas
        atlas = np.empty((F, 6 * F, 4), dtype=np.uint8)
        for i, (target, up) in enumerate(face_params):
            vm = p.computeViewMatrix(cam_pos, target, up)
            _, _, rgb, _, _ = p.getCameraImage(
                width=F, height=F,
                viewMatrix=vm,
                projectionMatrix=self.cube_proj,
                renderer=p.ER_BULLET_HARDWARE_OPENGL,
            )
            atlas[:, i * F:(i + 1) * F, :] = np.array(rgb, dtype=np.uint8).reshape(F, F, 4)

        # Remap the cubemap atlas into the equirectangular panorama
        equirect = cv2.remap(atlas, self._remap_x, self._remap_y,
                             cv2.INTER_LINEAR, borderMode=cv2.BORDER_WRAP)
        return equirect
    

