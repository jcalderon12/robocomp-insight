        self.plane = p.loadURDF("../../../../etc/URDFs/plane/plane.urdf", basePosition=[0, 0, 0]) 

        # LOAD CONCEPT IN THE SIMULATION
        self.concept = p.loadURDF("../../../../etc/URDFs/bump/bump_100x5cm.urdf", self.concept_position)
        # Paint the concept red to make it easily detectable in the images
        p.changeVisualShape(self.concept, -1, rgbaColor=[1, 0, 0, 1])  # Red color
        
        # LOAD ROBOT IN THE SIMULATION
        self.robot = p.loadURDF("../../../../etc/URDFs/shadow/shadow.urdf", self.concept_position, flags=flags)

        # Make ricoh_theta_z1 invisible to avoid it appearing in the camera images and interfering with the concept detection
        cam_link_id = self.get_link_info(self.robot).get("ricoh_theta_z1")
        if cam_link_id is not None:
            p.setCollisionFilterGroupMask(self.robot, cam_link_id, 0, 0)  # Disable collisions
            p.changeVisualShape(self.robot, cam_link_id, rgbaColor=[0, 0, 0, 0])  # Make invisible
        else:
            console.print("Camera link 'ricoh_theta_z1' not found in robot model. This should NOT happen. Exiting...", style="bold red")
            exit()

        # TImage getROI(int cx, int cy, int sx, int sy, int roiwidth, int roiheight);
        print("Waiting for camera image from robot...")
        self.robot_img = self.camera360rgb_proxy.getROI(-1, -1, -1, -1, -1, -1) # A bump in the way
        print(type(self.robot_img.image))
        # np from buffer (self.robot_img.image)
        robot_img_array = np.frombuffer(self.robot_img.image, dtype=np.uint8)
        # Display img array with cv2
        robot_img_array = robot_img_array.reshape((self.robot_img.height, self.robot_img.width, 3)) # RGBA
        cv2.imshow("Robot Camera Image", robot_img_array)
        cv2.waitKey(1)  # Needed to display the image window
        print("Camera image received from robot. Shape:")
        print(self.robot_img.width, self.robot_img.height)


        time.sleep(0.5)


        # ================ ROBOT PARAMETERS  ===============
        # ==================================================

        self.wheels_radius = 0.1
        self.distance_between_wheels = 0.44
        self.distance_from_center_to_wheels = self.distance_between_wheels / 2

        self.motors = ["frame_back_right2motor_back_right", "frame_back_left2motor_back_left", "frame_front_right2motor_front_right", "frame_front_left2motor_front_left"]
        self.joints_name = self.get_joints_info(self.robot)
        self.links_name = self.get_link_info(self.robot)

        self.init_pos, self.init_orn = p.getBasePositionAndOrientation(self.robot)
        self.forward_vel, self.angular_vel = 0, 0

        self.print_time = self.actual_time = self.initial_time = time.time()


        # ================ SIMULATION PARAM  ===============
        # ==================================================
        
        # Dataset initialization variables
        self.unsorted_image_list = []
        self.dataset_size = 16
        self.dataset = YoloDataset("concept_dataset", "concept")

        # Path parameters
        self.radius = 1.6
        angles = np.linspace(0, 2*np.pi, self.dataset_size, endpoint=False)
        self.robot_nav_path = [[self.concept_position[0] + self.radius*np.cos(angle), 
                            self.concept_position[1] + self.radius*np.sin(angle), 
                            0.01] for angle in angles]
        self.current_path_point = 0

        # Camera parameters (cubemap → equirectangular)
        self.cam_near = 0.01
        self.cam_far = 100
        self.cube_face_size = self.robot_img.height          # each cubemap face is square
        self.equirect_w = self.robot_img.width               # output equirectangular width
        self.equirect_h = self.robot_img.height              # output equirectangular height
        self.cube_proj = p.computeProjectionMatrixFOV(90, 1.0, self.cam_near, self.cam_far)
        self.cam_ricoh_offset = np.array([-0.16759, 0.0, 1.28231]) # ricoh_theta_z1 position relative to base_link
        self._build_equirect_remap()  # precompute lookup tables once
        
        # Status variables
        self.has_concept_been_found = False
    
        if startup_check:
            self.startup_check()
        else:
            self.timer.timeout.connect(self.compute)
            self.timer.start(self.Period)
        

        self.stage = "IDLE"

    def __del__(self):
        """Destructor"""


    @QtCore.Slot()
    def compute(self):
        self.show_compute_time_step()
        self.publish_status_to_dsr()
        
        match self.stage:
            case "IDLE":
                # If model already exists go directly to testing
                # Otherwise go to training
                self.stage = "TRAINING" 
                pass
            
            case "TRAINING":
                # Teleport robot to the next point in the path
                target_pos = self.robot_nav_path[self.current_path_point]
                p.resetBasePositionAndOrientation(self.robot, target_pos, self.init_orn)
                self.current_path_point = (self.current_path_point + 1) % self.dataset_size

                # Place the virtual eye at the ricoh_theta_z1 link origin.
                pos, ori = p.getBasePositionAndOrientation(self.robot)
                cam_pos = [
                    pos[0] + self.cam_ricoh_offset[0],
                    pos[1] + self.cam_ricoh_offset[1],
                    pos[2] + self.cam_ricoh_offset[2],
                ]

                # Forward direction matches the robot's own orientation (X-axis of the local frame)
                rot_matrix = p.getMatrixFromQuaternion(ori)
                forward = [rot_matrix[0], rot_matrix[3]]  # 2-D forward (x, y)

                # Render 360° panoramic strip
                panorama = self.render_360_image(cam_pos, forward)
                self.unsorted_image_list.append(panorama)

                # If we have enough images, create dataset and train model.
                if len(self.unsorted_image_list) >= self.dataset_size:
                    # We add 80% for training and 20% for validation
                    for i, img in enumerate(self.unsorted_image_list):
                        # Analyze the image with CV2 to detect a red bump (placeholder).
                        # Then, we use CV2 to generate a bounding box around the detected bump and create the corresponding label in YOLO format.
                        img = cv2.cvtColor(img, cv2.COLOR_RGBA2BGR)  # Convert RGBA to BGR (OpenCV native format)
                        hsv = cv2.cvtColor(img, cv2.COLOR_BGR2HSV)
                        lower_red = np.array([0, 70, 50])
                        upper_red = np.array([10, 255, 255])
                        mask = cv2.inRange(hsv, lower_red, upper_red)
                        debug_img = img.copy()
                        cv2.imwrite(f"debug-img/debug_image_{i}.png", debug_img)  # Save debug image with bounding box
                        contours, _ = cv2.findContours(mask, cv2.RETR_TREE, cv2.CHAIN_APPROX_SIMPLE)
                        if contours:
                            # Assume the largest contour is the bump
                            largest_contour = max(contours, key=cv2.contourArea)
                            x, y, w, h = cv2.boundingRect(largest_contour)
                            # Convert to YOLO format (class_id, x_center, y_center, width, height) normalized by image dimensions
                            img_h, img_w = img.shape[:2]
                            x_center = (x + w / 2) / img_w
                            y_center = (y + h / 2) / img_h
                            width = w / img_w
                            height = h / img_h
                            label = f"0 {x_center} {y_center} {width} {height}"  # Class 0 for bump

                            # DEBUG: Draw bounding box on the image and display it
                            cv2.rectangle(debug_img, (x, y), (x + w, y + h), (0, 255, 0), 2)
                        else:
                            # If no bump detected, create a label with zero size at the center (or skip)
                            label = "0 0.5 0.5 0 0"  # No object

                        if i < int(0.8 * self.dataset_size):
                            self.dataset.add_image(img, label, True)
                            print(f"Added image {i} to TRAINING set with label: {label}")
                        else:
                            self.dataset.add_image(img, label, False)
                            print(f"Added image {i} to VALIDATION set with label: {label}")

                    # Build dataset YAML
                    self.dataset.create_yaml()

                    # Train model
                    trainer = YoloTrainer(dataset_path=self.dataset.get_data_yaml_path(), model_name="yolov8n.pt", output_dir=f"yolo_concept_model")
                    trainer.init_training()
                    print(trainer.get_trained_model_path())
                    self.stage = "TESTING"
            
            case "TESTING":
                
                pass
        
        return True

