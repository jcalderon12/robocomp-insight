
# --- Common Agent Data ---
Agent.id = 0 # Change id
Agent.name = "semantic"

# --- Single Instance Configuration ---
# Use this if you only have one graph.
Agent.configFile = ""
Agent.domain = 0
Agent.tree = true
Agent.graph = true
Agent.2d = true
Agent.3d = true

# --- Multiple Instance Template ---
# If you define sub-instances, the single instance config above will be ignored.
# Agent.instance_name.configFile = ""
# Agent.instance_name.domain = 1
# Agent.instance_name.tree = true
# Agent.instance_name.graph = true
# Agent.instance_name.2d = true
# Agent.instance_name.3d = true

Period.Compute = 100
Period.Emergency = 500

Component.Debug.Verbose = true

Ice.Warn.Connections = "0"
Ice.Trace.Network = "0"
Ice.Trace.Protocol = "0"
Ice.MessageSizeMax = "20004800"

# --- GraphDB mirror (defaults shown explicitly) ---
graphDB.Enabled = true
graphDB.Endpoint = "http://localhost:7200"
graphDB.Repository = "insight_prod"
graphDB.NamedGraph = "urn:insight:semantic:live"

# --- Hypothesis generation ---
hypothesisGenerator.Enabled = true
hypothesisGenerator.OutputDir = "generated_hypotheses"
hypothesisGenerator.DescriptionPath = "../../description.md"
# Closed catalog of executable simulation interventions (shared contract with inner_simulator)
hypothesisGenerator.CatalogPath = "../../etc/intervention_catalog.json"
hypothesisGenerator.PrimaryModel = "gemma4:31b-cloud"

# Local fallback model. Must be downloaded beforehand with: ollama pull qwen3:14b
hypothesisGenerator.FallbackModel = "qwen3:14b"
hypothesisGenerator.OllamaBaseUrl = "http://localhost:11434"
hypothesisGenerator.RequestTimeoutSeconds = 300
hypothesisGenerator.InternalCount = 3
hypothesisGenerator.ExternalCount = 3
hypothesisGenerator.PreferredClient = "ollama_http"
hypothesisGenerator.DescriptionCharLimit = 3500

